# .crxignore — Files excluded from the Chrome Web Store package (veil-extension.zip)
# This is for documentation only (the build script uses an explicit include-list).

# Development / tooling
node_modules/
.git/
.venv/
__pycache__/
*.pyc
.env
.env.*
*.DS_Store
.idea/
.vscode/

# Python server — not included in extension package
scripts/
requirements.txt
requirements-dev.txt

# Tests
tests/
playwright.config.js
test-results/
coverage/

# CI / packaging output
.github/
dist/
*.zip
*.crx

# Documentation
*.md
LICENSE

# Package manager files
package.json
package-lock.json
yarn.lock

# Misc
*.log
*.sh
