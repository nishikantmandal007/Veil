{
  "name": "privacy-shield-llm",
  "version": "1.0.0",
  "description": "Privacy protection extension for LLM websites using GLiNER 2 for PII detection",
  "scripts": {
    "setup": "python3 -m venv .venv && . .venv/bin/activate && pip install --index-url https://download.pytorch.org/whl/cpu 'torch>=2.0.0' && pip install -r requirements.txt",
    "download-gliner2": ".venv/bin/python server/gliner2_server.py --download-only",
    "run-gliner2": ".venv/bin/python server/gliner2_server.py",
    "run-gliner2-lazy": ".venv/bin/python server/gliner2_server.py --lazy-load",
    "install-native-host-linux": "bash server/native-host/install_linux.sh",
    "remove-native-host-linux": "bash server/native-host/uninstall_linux.sh",
    "install-autostart-linux": "bash server/autostart/install_linux.sh",
    "remove-autostart-linux": "bash server/autostart/uninstall_linux.sh",
    "status-autostart-linux": "systemctl --user --no-pager status privacy-shield-gliner.service",
    "build": "echo 'No build step — load extension/ folder directly in Chrome'",
    "build:zip": "bash scripts/build_crx.sh",
    "lint": "eslint 'extension/*.js'",
    "format": "prettier --write 'extension/**/*.{js,json,css,html}'",
    "test": "node tests/js/test_background_utils.js",
    "test:unit": "node tests/js/test_background_utils.js",
    "test:unit:python": ".venv/bin/python -m pytest tests/server/ -v",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "dev": "echo 'Load the extension/ folder in Chrome via chrome://extensions (Developer mode)'"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/privacy-shield-llm"
  },
  "keywords": [
    "chrome-extension",
    "privacy",
    "pii-detection",
    "gliner",
    "llm",
    "security",
    "nlp",
    "ner"
  ],
  "author": "Your Name",
  "license": "MIT",
  "browser": {
    "fs": false,
    "path": false
  }
}